# 로컬 전용 설정 템플릿 (미커밋)
# 복사: copy src\main\resources\application-local.yaml.example src\main\resources\application-local.yaml
#
# OAuth 값은 아래처럼 직접 적거나, guide.md의 「.env」 방식으로 환경 변수만 쓸 수 있습니다.
# 두 방식을 혼용하지 않도록 하나를 선택하는 것을 권장합니다.

spring:
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: your-google-client-id
            client-secret: your-google-client-secret

          kakao:
            client-id: your-kakao-rest-api-key
            client-secret: your-kakao-client-secret

          naver:
            client-id: your-naver-client-id
            client-secret: your-naver-client-secret

server:
  port: 8080

logging:
  level:
    org.springframework.security: DEBUG
    org.springframework.security.oauth2: DEBUG
