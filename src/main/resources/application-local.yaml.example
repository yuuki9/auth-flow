# 로컬 개발 환경 설정 예제
# 이 파일을 복사하여 application-local.yaml로 저장하고 실제 값을 입력하세요!
# application-local.yaml은 .gitignore에 추가되어 있어 Git에 커밋되지 않습니다.

spring:
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: your-google-client-id
            client-secret: your-google-client-secret
          
          kakao:
            client-id: your-kakao-rest-api-key
            client-secret: your-kakao-client-secret  # 선택사항 (활성화한 경우만)
          
          naver:
            client-id: your-naver-client-id
            client-secret: your-naver-client-secret

server:
  port: 8080

logging:
  level:
    org.springframework.security: DEBUG
    org.springframework.security.oauth2: DEBUG
