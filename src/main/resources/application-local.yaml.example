# 이 파일을 application-local.yaml로 복사 후 실제 값으로 채우세요.
# application-local.yaml은 .gitignore에 의해 추적되지 않습니다.
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/authguide
    username: authuser
    password: authpass
  data:
    redis:
      host: localhost
      port: 6379

jwt:
  secret: your-256-bit-secret-key-here-must-be-at-least-32-chars
